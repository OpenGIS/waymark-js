{
  "signature": "createInstance(instanceDocument?)",
  "defaults": {
    "center": [0, 0],
    "zoom": 2,
    "attributionControl": false,
    "defaultBasemapVectorStyleURL": "https://tiles.openfreemap.org/styles/bright"
  },
  "lifecycleEvents": [
    "waymark:instance.created",
    "waymark:instance.recreated",
    "waymark:instance.destroyed"
  ],
  "forwardedMapEvents": [
    "waymark:map.load",
    "waymark:map.moveend",
    "waymark:map.zoomend",
    "waymark:map.rotateend",
    "waymark:map.pitchend",
    "waymark:map.error"
  ],
  "dataLayerEvents": [
    "waymark:data.layer.added",
    "waymark:data.layer.mounted",
    "waymark:data.layer.error"
  ]
}
