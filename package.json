{
  "name": "@ogis/waymark-js",
  "version": "3.0.0-alpha",
  "type": "module",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenGIS/Waymark-JS.git"
  },
  "bugs": {
    "url": "https://github.com/OpenGIS/Waymark-JS/issues"
  },
  "homepage": "https://github.com/OpenGIS/Waymark-JS#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/waymark-js.umd.cjs",
  "module": "./dist/waymark-js.js",
  "exports": {
    ".": {
      "import": "./dist/waymark-js.js",
      "require": "./dist/waymark-js.umd.cjs"
    },
    "./dist/waymark-js.css": "./dist/waymark-js.css"
  },
  "scripts": {
    "build": "vite build",
    "dev": "concurrently \"vite --host\" \"npm run test:watch\"",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "vitest": {
    "setupFiles": "./tests/setupTests.js"
  },
  "dependencies": {
    "@turf/bbox": "^7.3.2",
    "@turf/length": "^7.2.0",
    "lodash-es": "^4.17.22",
    "maplibre-gl": "^5.7.1",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jsdom": "^24.1.0",
    "less": "^4.2.0",
    "prettier": "^3.2.5",
    "vite": "^6.3.5",
    "vitest": "^4.0.17"
  }
}
