{
  "name": "waymark-js",
  "version": "2.0.0",
  "type": "module",
  "module": "./dist/waymark.js",
  "exports": {
    ".": {
      "import": "./dist/waymark.js"
    },
    "./waymark.css": "./dist/waymark.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.config.dev.js",
    "dev:browser-tests": "vite --config vite.config.dev.js --host 127.0.0.1 --port 4173 --strictPort",
    "build": "node scripts/skill-md.js && vite build --config vite.config.lib.js",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:contract": "node scripts/check-doc-test-contract.mjs",
    "api:contract": "node scripts/generate-api-contract.mjs",
    "docs:api-sync": "npm run api:contract && node scripts/check-api-doc-sync.mjs",
    "docs:sync": "npm run docs:contract && npm run docs:api-sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run format:check && npm run docs:sync && npm test && npm run test:browser"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0",
    "vue": "^3.5.38"
  }
}
